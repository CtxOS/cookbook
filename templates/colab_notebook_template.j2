r cache\n", "if has_gpu:\n", "    torch.cuda.empty_cache()\n", "gc.collect()\n", "\n", "{% if quantization == '4bit' %}\n", "# 4-bit quantization for memory efficiency\n", "model = AutoModelForCausalLM.from_pretrained(\n", "    \"{{ model_name }}\",\n", "    load_in_4bit=True,\n", "    device_map=\"auto\",\n", "    torch_dtype=torch.float16\n", ")\n", "{% else %}\n", "# Standard loading with memory optimization\n", "model = AutoModelForCausalLM.from_pretrained(\n", "    \"{{ model_name }}\",\n", "    torch_dtype=torch.float16,\n", "    device_map=\"auto\"\n", ")\n", "{% endif %}\n", "\n", "tokenizer = AutoTokenizer.from_pretrained(\"{{ model_name }}\")\n", "\n", "{% if 'finetune' in recipe_name.lower() %}\n", "# Prepare for fine-tuning\n", "model = prepare_model_for_kbit_training(model)\n", "\n", "# LoRA configuration for efficient fine-tuning\n", "lora_config = LoraConfig(\n", "    r=16,\n", "    lora_alpha=32,\n", "    target_modules=[\"q_proj\", \"v_proj\"],\n", "    lora_dropout=0.05,\n", "    bias=\"none\",\n", "    task_type=\"CAUSAL_LM\"\n", ")\n", "\n", "model = get_peft_model(model, lora_config)\n", "model.print_trainable_parameters()\n", "{% endif %}\n", "\n", "print(f\"Model loaded successfully!\")\n", "print(f\"Total parameters: {sum(p.numel() for p in model.parameters()):,}\")\n", "{% if 'finetune' in recipe_name.lower() %}\n", "print(f\"Trainable parameters: {sum(p.numel() for p in model.parameters() if p.requires_grad):,}\")\n", "{% endif %}"]}, {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["# Load and prepare dataset\n", "{% if dataset_name == 'local' %}\n", "# Local dataset configuration\n", "print(\"Please configure your local dataset loading:\")\n", "print(\"# from datasets import load_dataset\")\n", "print(\"# dataset = load_dataset('json', data_files='your_data.json')\")\n", "{% else %}\n", "from datasets import load_dataset\n", "\n", "print(f\"Loading dataset: {{ dataset_name }}\")\n", "try:\n", "    d